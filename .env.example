# ─────────────────────────────────────────────────────────────────────────
# Batua — single environment file (backend + frontend).
# Copy this file to .env and fill in values. .env is git-ignored.
# ─────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────
# MongoDB connection. If MongoDB is unreachable, the app automatically falls
# back to a local SQLite store at backend/data/store.db so it still runs.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="batua"

# CORS — comma-separated origins, or "*" for all (local single-user default).
CORS_ORIGINS="*"

# Google Gemini (optional). Leave empty to use the rule-based fallback.
# Get a key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ── Frontend (Create React App / craco) ──────────────────────────────────
# Must be prefixed REACT_APP_ to be exposed to the browser build.
REACT_APP_BACKEND_URL=http://localhost:8001
