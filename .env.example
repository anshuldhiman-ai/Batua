# ─────────────────────────────────────────────────────────────────────────
# Batua — single environment file (backend + frontend).
# Copy this file to .env and fill in values. .env is git-ignored.
# ─────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────
# MongoDB connection. If MongoDB is unreachable, the app automatically falls
# back to a local SQLite store at backend/data/store.db so it still runs.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="batua"

# CORS — comma-separated origins, or "*" for all.
# "*" is fine for LOCAL single-user use only. In PRODUCTION set this to your
# exact frontend URL (e.g. https://batua.vercel.app). Never ship "*" publicly:
# it lets any website call this API from a visitor's browser.
CORS_ORIGINS="*"

# Interactive API docs (/docs, /redoc, /openapi.json). OFF by default so a
# deploy doesn't expose the full API surface. Set to "1" locally if you want
# them; leave unset/"0" in production.
ENABLE_DOCS="0"

# Google Gemini (optional). Leave empty to use the rule-based fallback.
# Get a key from https://aistudio.google.com/app/apikey
# NOTE: rotate this key before any public deploy — see README "Security & Scope".
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ── Local LLM for the chat assistant (optional, recommended) ──────────────
# The finance chat assistant (AI Insights → chat) uses a LOCAL model via
# Ollama — no cloud, no Gemini, private. Answers stay varied and natural.
# Setup:
#   1) Install Ollama:  https://ollama.com/download
#   2) Pull a model:    ollama pull llama3.2   (~2 GB, runs on CPU)
# If Ollama isn't running, the assistant automatically falls back to
# deterministic (but still lightly varied) template answers.
LOCAL_LLM_URL="http://localhost:11434"
LOCAL_LLM_MODEL="llama3.2"
LOCAL_LLM_ENABLED="1"

# ── Offline voice input (optional, recommended) ──────────────────────────
# Chrome/Edge do speech recognition in Google's cloud, so the browser mic
# fails with a "network" error on networks that can't reach that service.
# With faster-whisper installed, voice notes are transcribed LOCALLY instead
# (no internet needed after the one-time model download) and the frontend
# auto-uses it. If it's not installed, the app falls back to the browser mic.
#   Install:  pip install faster-whisper   (already in requirements.txt)
#   First use downloads the model once (medium ≈ 1.5 GB), then works offline.
# Model sizes: tiny | base | small | medium | large-v3  (bigger = more accurate,
# slower, larger download + more RAM). "small" (~1 GB RAM) is a safe, accurate
# default for Hindi/Hinglish. Use "medium" only if you have >4 GB RAM free —
# it needs ~2.5 GB and will crash the server on low-memory machines.
WHISPER_ENABLED="1"
WHISPER_MODEL="small"        # startup default; switchable in-app (Settings →
                             # Voice input), and that choice is remembered
WHISPER_DEVICE="cpu"          # "cuda" if you have an NVIDIA GPU
WHISPER_COMPUTE="int8"        # int8 is fast/small on CPU; "float16" for GPU
# "auto" lets Whisper detect the language per clip — recommended. Forcing a
# code like "hi" can badly garble Hinglish/English speech (it tries to render
# English words in Devanagari). Set a fixed code only if your audio is always
# one language and detection is unreliable.
WHISPER_LANGUAGE="auto"

# Beam width for decoding. 1 = greedy (fast, good enough for short expense
# clips on CPU). 5 = classic beam search (max accuracy, ~3× slower).
# Default: 1.
# WHISPER_BEAM="1"

# Number of CPU threads for CTranslate2 inference. Defaults to all logical
# cores (os.cpu_count()). Lower this if Whisper is starving other processes.
# WHISPER_CPU_THREADS="4"

# ── Frontend (Vite) ──────────────────────────────────────────────────────
# Must be prefixed VITE_ to be exposed to the browser build.
VITE_BACKEND_URL=http://localhost:8001
